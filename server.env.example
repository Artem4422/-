# Скопируйте в server.env и заполните

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Telegram user ID администраторов через запятую (узнать: @userinfobot)
ADMIN_IDS=123456789

# Публичный HTTPS URL сервера для Web App (обязательно HTTPS в продакшене)
# Пример: https://parser.example.com
WEBAPP_URL=https://your-domain.com

# Хост и порт API
HOST=0.0.0.0
PORT=8080

# Папка данных (сессия, config, результаты)
PARSER_DATA_DIR=./server_data

# Опционально: секрет для API без Telegram initData (для отладки)
# API_SECRET=change-me
